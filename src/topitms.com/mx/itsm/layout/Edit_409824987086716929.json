    "script": "const { record, isInit, triggerBy, set = [], that, moment } = this;\nlet status = record.status\nlet formatRecordValues = \"\"\nlet triggerRecordFieldChange = \"\"\nif(status === \"409824987210645505\" && triggerBy != 'status'){\nthat.$router.push({\nname: \"page.record\",\nparams: { pageID: \"409824987080753153\", recordID:recordId}\n\n})\n}\nif (triggerBy === \"onsiteEngineer\") {\nconsole.log(\"onsiteEngineer:\",record.modalData.onsiteEngineer);\nconsole.log(\"onsiteEngineer11:\", window.recordField.Incident.onsiteEngineer.records)\n\nfor (let index = 0; index < window.recordField.Incident.onsiteEngineer.records.length; index++) {\n\nlet tem_onsiteEngineer = window.recordField.Incident.onsiteEngineer.records[index]\n\nconsole.log(\"onsiteEngineer22:\",tem_onsiteEngineer);\n\nif (tem_onsiteEngineer.recordID === record.modalData.onsiteEngineer) {\n\nconsole.log(\"333:\", tem_onsiteEngineer);\nrecord.modalData = {\n...record.modalData,\ncontactNo: tem_onsiteEngineer.values.phone\n}\n\n\nconsole.log(\"record.contactNo:\",record.contactNo);\n}\n}\n}\n\n\nif(record.modalData && !record.modalData.actualResolvedTime){\n    that.$set(record.modalData,'actualResolvedTime',moment.utc(new Date()).format())\n    }\n\nif (triggerBy === \"assignmentGroup\") {\n     record.assignee = undefined\n}\n\n\nreturn {\nrecord,\nformatRecordValues,\ntriggerRecordFieldChange\n}",

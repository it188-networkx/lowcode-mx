```json
{
  "_doc": {
    "description": "全局请求配置 — 支持多环境多租户，通过 active 切换当前使用的环境",
    "usage": "读取 active 字段获取当前环境名，再从 environments[active] 中获取 baseUrl 和 headers。每个环境下有多个 tenants，每个租户拥有独立的 API 连接参数和多个命名空间。"
  },
  "active": "{环境名称}",
  "environments": {
    "{环境名称}": {
      "description": "{环境描述，例如：开发环境}",
      "dirName": "{环境目录名，例如：dev.dms}",
      "tenants": {
        "{租户名称}": {
          "description": "{租户描述，例如：MX 租户}",
          "baseUrl": "http://{host}/{tenant}/pionapaas/api",
          "headers": {
            "Authorization": "Bearer {从服务端获取的 JWT Token}"
          }
        }
      }
    }
  }
}
